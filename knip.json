{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/server.ts!",
    "app/client.ts!",
    "app/routes/**/*.tsx!",
    "app/islands/**/*.tsx!",
    "scripts/*.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}!",
    "src/**/*.{ts,tsx}!",
    "scripts/**/*.ts"
  ],
  "ignoreDependencies": [
    "linalg-wasm",
    "cloudflare"
  ],
  "ignoreBinaries": [
    "wasm-pack"
  ]
}